# Database (use mysql:// — the schema uses drizzle-orm/mysql-core)
DATABASE_URL=mysql://zent:zent@localhost:3306/zent

# Redis
REDIS_URL=redis://localhost:6379

# Auth (min 32 chars — generate with: openssl rand -hex 32)
AUTH_SECRET=

# MinIO / S3-compatible storage
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=zent-uploads
MINIO_USE_SSL=false

# API
API_PORT=4000
API_HOST=0.0.0.0

# WebAuthn / Passkeys (set to your domain in production)
RP_ID=localhost
RP_ORIGIN=http://localhost:3000

# Snowflake ID generator
WORKER_ID=1
PROCESS_ID=1

# Node
NODE_ENV=development

# CORS
CORS_ORIGIN=http://localhost:3000

# Voice service (optional — only if running zent-stream)
# VOICE_SERVICE_URL=http://localhost:4005
# VOICE_INTERNAL_KEY=
